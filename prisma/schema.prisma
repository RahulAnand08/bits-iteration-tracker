generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Update {
  id        Int      @id @default(autoincrement())
  notice    String   @unique
  scrapedAt DateTime @default(now())
}

model Subscriber {
  id        Int      @id @default(autoincrement())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}